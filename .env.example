# ─────────────────────────────────────────────────────────────────────────────
# Buying-Moment Engine (GTM Maestro) — environment
# Copy to `.env.local` and fill in. Every key the project will ever need is named
# here. Third-party keys are Production-scoped only; preview deploys use fixtures.
#
# Stack — LOCKED 2026-07-07 (spec § Stack): Supabase (app-managed) · Anthropic +
# PDL (BYOK key-paste) · HubSpot (OAuth — CRM + send + analytics on ONE grant).
# Dropped this session: Clay, Apify. Outreach demoted to optional future adapter.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM: agentic research + brief synthesis (Anthropic Claude) — BYOK ──────────
# Opus 4.8 = brief voice; Sonnet 5 / Haiku 4.5 = research + extraction. Powers the
# buying-moment signal discovery (PDL has no data there) AND the brief voice.
ANTHROPIC_API_KEY=

# ── Enrichment: People Data Labs (PDL) — BYOK ─────────────────────────────────
# Synchronous REST (Person + Company Enrichment). Fills the verified gaps Claude
# can't reliably get — verified work email + LinkedIn URL. The waterfall is
# Claude-first → PDL gap-fill (metered per matched record into cost_events, R19).
PDL_API_KEY=

# ── Supabase: Auth (R18) + Postgres system of record (R17) — app-managed ───────
# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — full DB access; never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string used by Drizzle (postgres-js).
DATABASE_URL=

# ── App access allowlist (R18) ────────────────────────────────────────────────
# Comma-separated emails allowed to reach the app. Anything else -> /login.
ALLOWLIST_EMAILS=

# ── HubSpot: CRM + email send + analytics — ONE OAuth grant (R8) ──────────────
# OAuth 2.0 (internal/unverified app — no marketplace review). One "Connect
# HubSpot" grant covers CRM objects, Sequences enrollment (the whole-body-token
# send), and open/click/reply analytics. Access token ~30 min → refresh off
# expires_in. Per-tenant OAuth tokens are stored encrypted in the DB, not here.
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=
# App-managed key for encrypting per-tenant OAuth tokens at rest (AES-256-GCM).
# 32 bytes as base64 (or 64 hex chars). Generate: `openssl rand -base64 32`.
TOKEN_ENCRYPTION_KEY=

# ── HubSpot email SEND (U11) — the whole-body-{{custom_body}}-token trick ──────
# The pre-built HubSpot Sequence whose single step is `{{ contact.gtm_maestro_custom_body }}`
# (created once per portal). The AE's edited body is written into that contact
# property, then the contact is enrolled into this sequence — sending through the
# rep's connected inbox with native open/click/reply tracking.
HUBSPOT_SEQUENCE_ID=
# The rep's connected-inbox address the send goes through, and their HubSpot user id.
HUBSPOT_SENDER_EMAIL=
HUBSPOT_SENDER_USER_ID=
# ── D9 SEND FIREWALL (fail-closed) ────────────────────────────────────────────
# The demo NEVER emails a real practice. A send is allowed ONLY to a recipient
# whose address is registered here as sandbox/test. Empty => nothing sends.
# Comma-separated. Set the dev-account test addresses in U15.
SEND_SANDBOX_EMAILS=
SEND_SANDBOX_DOMAINS=
# "true" treats a `+sandbox` sub-address tag (e.g. qa+sandbox@gmail.com) as sandbox.
SEND_SANDBOX_ALLOW_SUBADDRESS=

# ── Signal-source data providers (R3 detectors) ──────────────────────────────
# Provisional — exact provider set is finalized in each detector's U4 recon.
# Official / ToS-clean sources preferred (D9). GDELT news = free, no key.
GOOGLE_PLACES_API_KEY=
YELP_API_KEY=
# Jobs source for the front-desk staffing-spike detector (Adzuna / CareerOneStop
# / ATS boards; SERP reseller fallback). Exact provider decided in U4 recon.
JOBS_API_KEY=

# ── Inngest: scheduled detector jobs (U3) ─────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Outreach: OPTIONAL future send adapter — credential-gated OFF (R10) ────────
# HubSpot covers send. Outreach is kept ONLY as an optional adapter for orgs that
# mandate a sales-engagement platform — absent by design, the adapter stays gated
# OFF until these exist. OAuth 2.0 only (no static keys); a dormant refresh token
# expires in ~14 days.
OUTREACH_CLIENT_ID=
OUTREACH_CLIENT_SECRET=
OUTREACH_REFRESH_TOKEN=
