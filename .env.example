# ─────────────────────────────────────────────────────────────────────────────
# Buying-Moment Engine (GTM Maestro) — environment
# Copy to `.env.local` and fill in. Every key the project will ever need is named
# here. Third-party keys are Production-scoped only; preview deploys use fixtures.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM: brief synthesis (Claude / Anthropic, runtime model Opus 4.8) ──────────
ANTHROPIC_API_KEY=

# ── Supabase: Auth (R18) + Postgres system of record (R17) ────────────────────
# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — full DB access; never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string used by Drizzle (postgres-js).
DATABASE_URL=

# ── App access allowlist (R18) ────────────────────────────────────────────────
# Comma-separated emails allowed to reach the app. Anything else -> /login.
ALLOWLIST_EMAILS=

# ── Clay: enrichment (R9) ─────────────────────────────────────────────────────
CLAY_API_KEY=
# Shared secret the Clay HTTP-API column signs enrich callbacks with. The
# /api/enrich-callback route rejects any request without it.
CLAY_CALLBACK_SECRET=

# ── HubSpot: CRM integration (R8) ─────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=

# ── Signal-source data providers (R3 detectors) ──────────────────────────────
# Jobs/news/reviews search provider (e.g. SERP/JSearch/news API).
SEARCH_API_KEY=
# Apify — review/job scraper actors (fallback source path).
APIFY_TOKEN=

# ── Inngest: scheduled detector jobs (U3) ─────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Outreach: send path — BUILT but credential-gated OFF (R10) ────────────────
# Absent by design — the send path stays gated OFF until these exist. Outreach is
# OAuth 2.0 only (no static keys); a dormant refresh token expires in ~14 days.
OUTREACH_CLIENT_ID=
OUTREACH_CLIENT_SECRET=
OUTREACH_REFRESH_TOKEN=
